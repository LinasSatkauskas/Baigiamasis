# Database Configuration
MySQL:Db=your_database_name
MySQL:User=your_mysql_user
MySQL:Password=your_mysql_password

# SMTP Email Configuration (optional - if not set, emails are saved to files)
Smtp:Host=smtp.gmail.com
Smtp:Port=587
Smtp:User=your_email@gmail.com
Smtp:Password=your_app_password
Smtp:FromAddress=noreply@yourapp.com

# Application Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5166
