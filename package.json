{
  "scripts": {
    "dev": "concurrently -k -n server,client \"dotnet run --project ReactApp1.Server/ReactApp1.Server.csproj --launch-profile http\" \"npm --prefix reactapp1.client run dev\"",
    "dev:server": "dotnet run --project ReactApp1.Server/ReactApp1.Server.csproj --launch-profile http",
    "dev:client": "npm --prefix reactapp1.client run dev",
    "build": "npm --prefix reactapp1.client run build && npm run copy-assets",
    "copy-assets": "node copy-assets.js",
    "start": "dotnet run --project ReactApp1.Server/ReactApp1.Server.csproj --launch-profile http"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.1.15",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "node": "^24.9.0",
    "node.js": "^0.0.1-security",
    "react": "^19.2.0",
    "react-hook-form": "^7.65.0",
    "react-router-dom": "^7.9.5",
    "zustand": "^5.0.8"
  }
}
